#!/usr/bin/env bash
#
# widget-switch - Reliably switch WidgetCatalog layouts via ADB
#
# Usage:
#   widget-switch LAYOUT [WAIT_SECONDS]
#
# Arguments:
#   LAYOUT         Layout name (e.g., BoxSample1, TextSample1, SystemThemeSample, etc.)
#   WAIT_SECONDS   Optional render wait time (default: 1.5)
#
# Examples:
#   widget-switch BoxSample1
#   widget-switch SystemThemeSample 2
#
# Notes:
#   - Requires ANDROID_SERIAL to be set or a single device connected
#   - Total time is typically ~1.5-2 seconds
#   - The widget tile must be added first (use --init for first-time setup)

set -euo pipefail

PACKAGE="com.google.example.wear_widget"
SERVICE=".WidgetCatalogService"
RECEIVER=".WidgetCatalogReceiver"
COMPONENT="$PACKAGE/$SERVICE"

usage() {
    cat <<EOF
Usage: $(basename "$0") LAYOUT [WAIT_SECONDS]
       $(basename "$0") --init
       $(basename "$0") --list

Switch WidgetCatalog layouts reliably via ADB.

Arguments:
  LAYOUT         Layout name to switch to
  WAIT_SECONDS   Render wait time in seconds (default: 1.5)

Options:
  --init         First-time setup: force-stop and add tile
  --list         List available layouts

Examples:
  $(basename "$0") --init          # First-time setup
  $(basename "$0") BoxSample1      # Switch to BoxSample1
  $(basename "$0") TextSample1 2   # Switch with 2s render wait
EOF
    exit 0
}

list_layouts() {
    echo "Available layouts:"
    echo "  SemanticStyleWorkaroundSample"
    echo "  CanvasSample3"
    echo "  SystemThemeComparisonSample"
    echo "  SystemThemeSample"
    echo "  AustralianThemeSample"
    echo "  BoxSample1"
    echo "  BoxSample2"
    echo "  BoxSample3"
    echo "  TextSample1"
    echo "  TextSample1WithMargin"
    echo "  RowSample1"
    echo "  RowSample2"
    echo "  CollapsibleColumnSample1"
    echo "  ButtonSample1"
    echo "  ButtonSample2"
    echo "  ButtonSample3"
    echo "  ButtonSample4"
    echo "  ButtonSample6"
    echo "  ButtonSample7"
    echo "  ButtonSample8"
    echo "  ButtonSample9"
    echo "  IconSample1"
    echo "  GridSample1"
    echo "  CardSample1"
    echo "  CounterSample1"
    echo "  Material3ThemeSample"
    echo "  CanvasSample1"
    echo "  CanvasSample2"
    echo "  GradientBackgroundSample"
    echo "  PendingIntentSample"
    echo "  VerticalScrollSample"
    echo "  MixedStyleSample"
    echo "  ConditionalRadiusSample"
    echo "  TypographyScaleSample"
    echo "  AnchoredTextSample"
    echo "  RotatedTextSample"
    echo "  FullBleedImageButtonSample"
    exit 0
}

init_tile() {
    echo "Initializing WidgetCatalog tile..."
    adb shell am force-stop "$PACKAGE"
    sleep 0.5
    OUTPUT=$(adb shell am broadcast \
        -a com.google.android.wearable.app.DEBUG_SURFACE \
        --es operation add-tile \
        --ecn component "$COMPONENT")

    # Extract Index (e.g., from Index=[0])
    INDEX=$(echo "$OUTPUT" | grep -o 'Index=\[[0-9]*\]' | sed 's/Index=\[\([0-9]*\)\]/\1/')

    if [ -n "$INDEX" ]; then
        sleep 0.5
        adb shell am broadcast \
            -a com.google.android.wearable.app.DEBUG_SYSUI \
            --es operation show-tile \
            --ei index "$INDEX" > /dev/null
        echo "Tile initialized (Index: $INDEX). Wait 2-3 seconds for render."
    else
        echo "Warning: Could not determine tile index. Trying index 0."
        sleep 0.5
        adb shell am broadcast \
            -a com.google.android.wearable.app.DEBUG_SYSUI \
            --es operation show-tile \
            --ei index 0 > /dev/null
        echo "Tile initialized. Wait 2-3 seconds for render."
    fi
    exit 0
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

if [[ "${1:-}" == "--list" ]]; then
    list_layouts
fi

if [[ "${1:-}" == "--init" ]]; then
    init_tile
fi

if [[ $# -lt 1 ]]; then
    echo "$(basename "$0"): layout name required" >&2
    echo "Try '$(basename "$0") --help' for usage" >&2
    exit 1
fi

LAYOUT="$1"
WAIT="${2:-1.5}"

# Validate layout name
VALID_LAYOUTS="SemanticStyleWorkaroundSample CanvasSample3 SystemThemeComparisonSample SystemThemeSample AustralianThemeSample BoxSample1 BoxSample2 BoxSample3 TextSample1 TextSample1WithMargin RowSample1 RowSample2 CollapsibleColumnSample1 ButtonSample1 ButtonSample2 ButtonSample3 ButtonSample4 ButtonSample6 ButtonSample7 ButtonSample8 ButtonSample9 IconSample1 GridSample1 CardSample1 CounterSample1 Material3ThemeSample CanvasSample1 CanvasSample2 GradientBackgroundSample PendingIntentSample VerticalScrollSample MixedStyleSample ConditionalRadiusSample TypographyScaleSample AnchoredTextSample RotatedTextSample FullBleedImageButtonSample ReproBitmapCanvas"

if ! echo "$VALID_LAYOUTS" | grep -qw "$LAYOUT"; then
    echo "$(basename "$0"): unknown layout '$LAYOUT'" >&2
    echo "Use --list to see available layouts" >&2
    exit 1
fi

echo "Switching to layout: $LAYOUT..."

# Generate a unique marker to synchronize logs
MARKER="SWITCH_START_$(date +%s)"
LOG_FILE=$(mktemp)

# Start monitoring logcat in background
# We capture both our marker and the app's output
adb logcat -s WidgetSwitchMarker:I WidgetCatalog:D -v time > "$LOG_FILE" &
LOG_PID=$!

# Ensure cleanup on exit
trap 'kill "$LOG_PID" 2>/dev/null || true; rm -f "$LOG_FILE"' EXIT

# Wait a moment for logcat to connect
sleep 0.5

# Emit the start marker log
adb shell log -t WidgetSwitchMarker "$MARKER"

# Broadcast the intent
adb shell am broadcast \
    -n "$PACKAGE/$RECEIVER" \
    -a "$PACKAGE.SET_WIDGET" \
    --es widget "$LAYOUT" > /dev/null

echo "Waiting for widget update (monitoring logs)..."

TIMEOUT=30
START_TIME=$(date +%s)

while true; do
    if [ -f "$LOG_FILE" ]; then
        # Read the log file
        CONTENT=$(cat "$LOG_FILE")

        # Check if our marker has appeared
        if [[ "$CONTENT" == *"$MARKER"* ]]; then
            # Check for the specific success message appearing AFTER the marker
            # This handles the case where the same layout is re-applied
            AFTER_MARKER=${CONTENT#*"$MARKER"}
            
            if [[ "$AFTER_MARKER" == *"provideWidgetData: layoutName='$LAYOUT'"* ]]; then
                echo "Success: Widget updated to '$LAYOUT'."
                break
            fi
        fi
    fi

    CURRENT_TIME=$(date +%s)
    ELAPSED=$((CURRENT_TIME - START_TIME))

    if [ "$ELAPSED" -ge "$TIMEOUT" ]; then
        echo "Error: Timeout waiting for widget update (30s)." >&2
        echo "Possible reasons: App crashed, system slow, or log missed." >&2
        exit 1
    fi

    sleep 0.5
done
