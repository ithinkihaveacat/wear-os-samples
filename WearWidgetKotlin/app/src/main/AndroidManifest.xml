<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".WearWidgetApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />
        <uses-library
            android:name="wear-sdk"
            android:required="false" />
        <!--
               Set to true if your app is Standalone, that is, it does not require the handheld
               app to run.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

    <service
        android:name=".HelloWidgetService"
        android:exported="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/hello_widget_label"
        android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">

        <intent-filter>
            <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
            <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
        </intent-filter>

        <meta-data
            android:name="androidx.glance.wear.widget.provider"
            android:resource="@xml/hello_widget_info" />

        <meta-data
            android:name="androidx.wear.tiles.PREVIEW"
            android:resource="@drawable/hello_widget_fullscreen" />
    </service>

    <activity
        android:name=".ForceUpdateActivity"
        android:exported="true"
        android:label="@string/force_update_label"
        android:theme="@android:style/Theme.DeviceDefault">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <service
        android:name=".ForceUpdateService"
        android:exported="true"
        android:label="@string/force_update_label"
        android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">

        <intent-filter>
            <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
            <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
        </intent-filter>

        <meta-data
            android:name="androidx.glance.wear.widget.provider"
            android:resource="@xml/force_update_widget_info" />

        <meta-data
            android:name="androidx.wear.tiles.PREVIEW"
            android:resource="@drawable/force_update_fullscreen" />
    </service>

        <service
            android:name=".WidgetCatalogService"
            android:exported="true"
            android:icon="@drawable/ic_launcher"
            android:label="@string/widget_catalog_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">

            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/widget_catalog_info" />

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/widget_catalog_fullscreen" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ComponentCatalogService"
            android:exported="true"
            android:icon="@drawable/ic_launcher"
            android:label="@string/component_catalog_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">

            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/component_catalog_info" />

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/component_catalog_fullscreen" />
        </service>

        <receiver
            android:name=".ComponentCatalogReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.example.wear_widget.SET_COMPONENT" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".WidgetCatalogReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.example.wear_widget.SET_WIDGET" />
                <action android:name="com.google.example.wear_widget.DEBUG_CLICK_ACTION" />
            </intent-filter>
        </receiver>

    </application>

</manifest>