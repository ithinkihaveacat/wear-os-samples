#!/usr/bin/env bash
#
# component-switch - Reliably switch ComponentCatalog widget layouts via ADB
#
# Usage:
#   component-switch LAYOUT
#
# Arguments:
#   LAYOUT         Layout name (textButton, iconButton, avatarButton, imageButton,
#                  compactButton, titleCard, appCard, circularProgressIndicator,
#                  segmentedCircularProgressIndicator, fullBleedImage, animatedBox)
#
# Examples:
#   component-switch textButton
#   component-switch appCard
#
# Notes:
#   - Requires ANDROID_SERIAL to be set or a single device connected
#   - Total time is fast (uses debug commands to bypass throttle)

set -euo pipefail

PACKAGE="com.google.example.wear_widget"
SERVICE=".ComponentCatalogService"
RECEIVER=".ComponentCatalogReceiver"
COMPONENT="$PACKAGE/$SERVICE"

VALID_LAYOUTS="textButton iconButton avatarButton imageButton compactButton titleCard appCard textDataCard iconDataCard graphicDataCard circularProgressIndicator segmentedCircularProgressIndicator fullBleedImage animatedBox"

usage() {
    cat <<EOF
Usage: $(basename "$0") LAYOUT
       $(basename "$0") --list
       $(basename "$0") --all

Switch ComponentCatalog widget layouts reliably via ADB.

Arguments:
  LAYOUT         Layout name to switch to

Options:
  --list         List available layouts
  --all          Switch through all available layouts sequentially

Examples:
  $(basename "$0") textButton      # Switch to textButton layout
EOF
    exit 0
}

list_layouts() {
    for layout in $VALID_LAYOUTS; do
        echo "$layout"
    done
    exit 0
}

switch_all() {
    for layout in $VALID_LAYOUTS; do
        echo "------------------------------------------------------------"
        echo "Switching to: $layout"
        "$0" "$layout" || echo "Error: Failed to switch to $layout"
    done
    exit 0
}

require() { hash "$@" || exit 127; }

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

if [[ "${1:-}" == "--list" ]]; then
    list_layouts
fi

if [[ "${1:-}" == "--all" ]]; then
    require adb
    switch_all
fi

if [[ $# -lt 1 ]]; then
    echo "$(basename "$0"): layout name required" >&2
    echo "Try '$(basename "$0") --help' for usage" >&2
    exit 1
fi

require adb

# Check device availability
if ! adb get-state >/dev/null 2>&1; then
  if [[ -n "${ANDROID_SERIAL:-}" ]]; then
    echo "$(basename "$0"): device '$ANDROID_SERIAL' not available" >&2
  else
    echo "$(basename "$0"): no device connected" >&2
  fi
  exit 1
fi

LAYOUT="$1"

# Validate layout name
VALID_LAYOUTS="textButton iconButton avatarButton imageButton compactButton titleCard appCard textDataCard iconDataCard graphicDataCard circularProgressIndicator segmentedCircularProgressIndicator fullBleedImage animatedBox"
if ! echo "$VALID_LAYOUTS" | grep -qw "$LAYOUT"; then
    echo "$(basename "$0"): unknown layout '$LAYOUT'" >&2
    echo "Use --list to see available layouts" >&2
    exit 1
fi

echo "Switching to layout: $LAYOUT..."

# 1. Start Logcat monitoring
# We monitor for "State saved" which confirms the DataStore has been updated.
LOG_FILE=$(mktemp)
# Note: Log tag for ComponentCatalogReceiver is "ComponentCatalogRcvr"
adb logcat -s ComponentCatalogRcvr:D -v time > "$LOG_FILE" &
LOG_PID=$!
trap 'kill "$LOG_PID" 2>/dev/null || true; rm -f "$LOG_FILE"' EXIT
sleep 0.5

# 2. Send SET_COMPONENT broadcast
adb shell am broadcast \
    -n "$PACKAGE/$RECEIVER" \
    -a "$PACKAGE.SET_COMPONENT" \
    --es layout "$LAYOUT" > /dev/null

# 3. Wait for "State saved" confirmation
# We need to ensure the data store is updated before we ask for the tile
# otherwise we might get the old layout.
echo "Waiting for state save..."
TIMEOUT=10
START_TIME=$(date +%s)
STATE_SAVED=false

while true; do
    if grep -q "State saved" "$LOG_FILE"; then
        STATE_SAVED=true
        break
    fi
    CURRENT_TIME=$(date +%s)
    if [ $((CURRENT_TIME - START_TIME)) -ge $TIMEOUT ]; then
        break
    fi
    sleep 0.1
done

if [ "$STATE_SAVED" = false ]; then
    echo "Error: Timeout waiting for 'State saved' log." >&2
    exit 1
fi

# 4. Refresh Tile and Wait for Visibility using adb-tile-add
# We delegate to the shared skill script which handles the robust
# visibility checks and remote compose failure detection.
ADB_TILE_ADD="${HOME}/.agents/skills/adb/scripts/adb-tile-add"

if [ ! -x "$ADB_TILE_ADD" ]; then
    echo "Error: adb-tile-add not found at $ADB_TILE_ADD" >&2
    echo "Please ensure the adb agent skill is installed." >&2
    exit 1
fi

if "$ADB_TILE_ADD" --wait "$COMPONENT"; then
    echo "Success: Widget updated to '$LAYOUT'."
else
    echo "Error: Failed to refresh and verify tile visibility." >&2
    exit 1
fi
