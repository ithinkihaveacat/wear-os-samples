#!/usr/bin/env bash
#
# component-switch - Reliably switch ComponentCatalog widget layouts via ADB
#
# Usage:
#   component-switch LAYOUT
#
# Arguments:
#   LAYOUT         Layout name (textButton, iconButton, avatarButton, imageButton,
#                  compactButton, titleCard, appCard, circularProgressIndicator,
#                  segmentedCircularProgressIndicator, fullBleedImage, animatedBox)
#
# Examples:
#   component-switch textButton
#   component-switch appCard
#
# Notes:
#   - Requires ANDROID_SERIAL to be set or a single device connected
#   - Total time is fast (uses debug commands to bypass throttle)

set -euo pipefail

PACKAGE="com.google.example.wear_widget"
SERVICE=".ComponentCatalogService"
RECEIVER=".ComponentCatalogReceiver"
COMPONENT="$PACKAGE/$SERVICE"

usage() {
    cat <<EOF
Usage: $(basename "$0") LAYOUT
       $(basename "$0") --list

Switch ComponentCatalog widget layouts reliably via ADB.

Arguments:
  LAYOUT         Layout name to switch to

Options:
  --list         List available layouts

Available layouts:
  textButton, iconButton, avatarButton, imageButton, compactButton,
  titleCard, appCard, circularProgressIndicator,
  segmentedCircularProgressIndicator, fullBleedImage, animatedBox

Examples:
  $(basename "$0") textButton      # Switch to textButton layout
EOF
    exit 0
}

list_layouts() {
    echo "Available layouts:"
    echo "  textButton"
    echo "  iconButton"
    echo "  avatarButton"
    echo "  imageButton"
    echo "  compactButton"
    echo "  titleCard"
    echo "  appCard"
    echo "  circularProgressIndicator"
    echo "  segmentedCircularProgressIndicator"
    echo "  fullBleedImage"
    echo "  animatedBox"
    exit 0
}

require() { hash "$@" || exit 127; }

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

if [[ "${1:-}" == "--list" ]]; then
    list_layouts
fi

if [[ $# -lt 1 ]]; then
    echo "$(basename "$0"): layout name required" >&2
    echo "Try '$(basename "$0") --help' for usage" >&2
    exit 1
fi

require adb

# Check device availability
if ! adb get-state >/dev/null 2>&1; then
  if [[ -n "${ANDROID_SERIAL:-}" ]]; then
    echo "$(basename "$0"): device '$ANDROID_SERIAL' not available" >&2
  else
    echo "$(basename "$0"): no device connected" >&2
  fi
  exit 1
fi

LAYOUT="$1"

# Validate layout name
VALID_LAYOUTS="textButton iconButton avatarButton imageButton compactButton titleCard appCard textDataCard iconDataCard graphicDataCard circularProgressIndicator segmentedCircularProgressIndicator fullBleedImage animatedBox"
if ! echo "$VALID_LAYOUTS" | grep -qw "$LAYOUT"; then
    echo "$(basename "$0"): unknown layout '$LAYOUT'" >&2
    echo "Use --list to see available layouts" >&2
    exit 1
fi

echo "Switching to layout: $LAYOUT..."

# 1. Start Logcat monitoring
# We monitor for "State saved" which confirms the DataStore has been updated.
LOG_FILE=$(mktemp)
# Note: Log tag for ComponentCatalogReceiver is "ComponentCatalogRcvr"
adb logcat -s ComponentCatalogRcvr:D -v time > "$LOG_FILE" &
LOG_PID=$!
trap 'kill "$LOG_PID" 2>/dev/null || true; rm -f "$LOG_FILE"' EXIT
sleep 0.5

# 2. Send SET_COMPONENT broadcast
adb shell am broadcast \
    -n "$PACKAGE/$RECEIVER" \
    -a "$PACKAGE.SET_COMPONENT" \
    --es layout "$LAYOUT" > /dev/null

# 3. Wait for "State saved" confirmation
# We need to ensure the data store is updated before we ask for the tile
# otherwise we might get the old layout.
echo "Waiting for state save..."
TIMEOUT=10
START_TIME=$(date +%s)
STATE_SAVED=false

while true; do
    if grep -q "State saved" "$LOG_FILE"; then
        STATE_SAVED=true
        break
    fi
    CURRENT_TIME=$(date +%s)
    if [ $((CURRENT_TIME - START_TIME)) -ge $TIMEOUT ]; then
        break
    fi
    sleep 0.1
done

if [ "$STATE_SAVED" = false ]; then
    echo "Error: Timeout waiting for 'State saved' log." >&2
    exit 1
fi

# 4. Refresh Tile using DEBUG_SURFACE
# This debug command bypasses standard throttling.
OUTPUT=$(adb shell am broadcast \
    -a com.google.android.wearable.app.DEBUG_SURFACE \
    --es operation add-tile \
    --ecn component "$COMPONENT")

# Extract Index
INDEX=$(echo "$OUTPUT" | grep -o 'Index=\[[0-9]*\]' | sed 's/Index=\[\([0-9]*\)\]/\1/')

if [ -n "$INDEX" ]; then
    # Wait for the widget to be fully displayed to avoid screenshot issues
    echo "Waiting for visibility..."
    
    # Start monitoring SysUI and potential errors
    VISIBILITY_LOG=$(mktemp)
    adb logcat -v time SysUI:I ProtoTilesTileRendererImpl:E AndroidRuntime:E *:S > "$VISIBILITY_LOG" &
    VISIBILITY_PID=$!
    # Update trap to kill both PIDs
    trap 'kill "$LOG_PID" "$VISIBILITY_PID" 2>/dev/null || true; rm -f "$LOG_FILE" "$VISIBILITY_LOG"' EXIT

    adb shell am broadcast \
        -a com.google.android.wearable.app.DEBUG_SYSUI \
        --es operation show-tile \
        --ei index "$INDEX" > /dev/null

    START_TIME=$(date +%s)
    TIMEOUT=10
    VISIBLE=false

    while true; do
        CURRENT_TIME=$(date +%s)
        ELAPSED=$((CURRENT_TIME - START_TIME))
        
        if [ $ELAPSED -ge $TIMEOUT ]; then
            echo "Warning: Timeout waiting for tile visibility ($TIMEOUT s)."
            break
        fi

        # Check for Success
        if grep -q "Visible tile added" "$VISIBILITY_LOG"; then
            VISIBLE=true
            break
        fi

        # Check for Failures
        if grep -q "FATAL EXCEPTION" "$VISIBILITY_LOG"; then
            echo "Error: App crash detected!"
            grep -A 5 "FATAL EXCEPTION" "$VISIBILITY_LOG"
            exit 1
        fi
        if grep -q "Error getting tile response" "$VISIBILITY_LOG"; then
            echo "Error: Renderer failed to get tile response."
            grep "Error getting tile response" "$VISIBILITY_LOG"
            exit 1
        fi

        sleep 0.2
    done

    if [ "$VISIBLE" = true ]; then
        # Continue monitoring for a short buffer to catch immediate crashes
        sleep 1.5
        if grep -q "FATAL EXCEPTION" "$VISIBILITY_LOG"; then
            echo "Error: App crash detected after visibility!"
            grep -A 5 "FATAL EXCEPTION" "$VISIBILITY_LOG"
            exit 1
        fi
        if grep -q "Error getting tile response" "$VISIBILITY_LOG"; then
            echo "Error: Renderer failed to get tile response."
            grep "Error getting tile response" "$VISIBILITY_LOG"
            exit 1
        fi
        echo "Success: Widget updated to '$LAYOUT'."
    else
         echo "Warning: Widget might not be visible (signal missed)."
    fi
else
    echo "Error: Failed to refresh tile." >&2
    echo "Output: $OUTPUT"
    exit 1
fi
