#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<EOF
Usage: $(basename "$0") COMPOSABLE_NAME

Take a headless screenshot of a RemoteComposable using Robolectric.

Arguments:
  COMPOSABLE_NAME   Name of the composable function (e.g., AustralianThemeSample, textButton)

Examples:
  $(basename "$0") AustralianThemeSample
  $(basename "$0") ButtonSample1
  $(basename "$0") textButton
EOF
    exit 0
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

if [[ $# -lt 1 ]]; then
    echo "$(basename "$0"): composable name required" >&2
    echo "Try '$(basename "$0") --help' for usage" >&2
    exit 1
fi

TARGET="$1"

echo "Generating screenshot for $TARGET..."

if ! ./gradlew testDebugUnitTest --tests "com.google.example.wear_widget.RoboScreenshotToolTest" -Drobo.screenshot.target="$TARGET" --quiet; then
    echo "Error: Screenshot generation failed. Check if '$TARGET' is a valid composable." >&2
    exit 1
fi

OUTPUT_PATH="app/screenshots/${TARGET}.png"
if [[ -f "$OUTPUT_PATH" ]]; then
    echo "Success: Screenshot saved to \$PWD/$OUTPUT_PATH"
else
    echo "Error: Test passed but screenshot was not found at $OUTPUT_PATH" >&2
    exit 1
fi
