#!/usr/bin/env bash
set -euo pipefail

echo "DEPRECATED: Please use 'compose-preview' instead." >&2
echo "Example: compose-preview show --filter YourPreviewName" >&2
echo "" >&2

# Forward to compose-preview if possible
if command -v compose-preview >/dev/null 2>&1; then
  # Basic mapping of arguments
  if [[ "${1:-}" == "--all" ]]; then
    unset ANDROID_JAR && compose-preview show
  elif [[ "${1:-}" == "--list" ]]; then
    unset ANDROID_JAR && compose-preview list
  elif [[ -n "${1:-}" ]]; then
    FILTER="$1"
    if [[ "$FILTER" == "--preview" ]]; then
       FILTER="${2:-}"
    fi
    unset ANDROID_JAR && compose-preview show --filter "$FILTER"
  else
    unset ANDROID_JAR && compose-preview show
  fi
else
  echo "Error: 'compose-preview' not found. Please follow the instructions in AGENTS.md to install it." >&2
  exit 1
fi
